# Port for the dashboard
PORT=4000

# --- Optional: org-wide Anthropic API usage (separate from your Max plan) ---
# Only useful if you also call the API directly with code. Leave blank otherwise.
# Get an Admin API key from https://console.anthropic.com/settings/admin-keys
ANTHROPIC_ADMIN_KEY=

# --- Optional: claude.ai web session (UNOFFICIAL, undocumented endpoint) ---
# Reads your Max plan limit metadata from claude.ai. The endpoint is NOT a
# public API; field names can change without notice. Treat sessionKey as a
# password — anyone with it can act as you on claude.ai.
#
# How to get sessionKey:
#   1. Open https://claude.ai in your browser (logged in)
#   2. DevTools → Application → Cookies → https://claude.ai
#   3. Copy the value of the "sessionKey" cookie (starts with sk-ant-sid01-…)
#
# How to get your org id:
#   - It's in the claude.ai URL after you select an org, OR
#   - Call GET /api/organizations once you have a sessionKey
CLAUDE_AI_SESSION_KEY=sk-ant-sid01-REPLACE_WITH_YOUR_OWN_SESSION_KEY
CLAUDE_AI_ORG_ID=00000000-0000-0000-0000-000000000000

# --- Optional: client fingerprint headers ---
# claude.ai sometimes rejects requests missing these. Pull them from any
# /api/organizations/... request in DevTools → Network → Headers.
CLAUDE_AI_CLIENT_SHA=
CLAUDE_AI_CLIENT_VERSION=1.0.0
CLAUDE_AI_DEVICE_ID=
CLAUDE_AI_ANONYMOUS_ID=

# --- Optional: Slack notifications ---
# Get a webhook URL from: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
# Channel to post to (default: #claude-usage)
SLACK_CHANNEL=#claude-usage
# Comma-separated usage thresholds for alerts (default: 80,90,95)
SLACK_THRESHOLDS=80,90,95
# Time to send daily summary in 24h format (default: 09:00)
SLACK_DAILY_SUMMARY_TIME=09:00
